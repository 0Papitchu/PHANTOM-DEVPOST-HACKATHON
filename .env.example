# phantom-ui-navigator/.env.example
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── GCP ──────────────────────────────────────────────────────
GCP_PROJECT_ID=phantom-ui-navigator
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./phantom-sa-key.json

# ── Gemini AI ────────────────────────────────────────────────
# Option 1 : Clé API directe (dev local)
GEMINI_API_KEY=
# Option 2 : Via Secret Manager (production) — laissez vide
GEMINI_MODEL=gemini-2.0-flash

# ── Cloud Storage ────────────────────────────────────────────
STORAGE_BUCKET=phantom-screenshots-157502772725

# ── Pub/Sub ──────────────────────────────────────────────────
PUBSUB_TOPIC_SCREENSHOTS=phantom-screenshots
PUBSUB_TOPIC_ANALYSIS=phantom-analysis
PUBSUB_TOPIC_ACTIONS=phantom-actions

# ── Browser ──────────────────────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_DEFAULT_URL=https://www.google.com
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720

# ── Screenshot Agent ─────────────────────────────────────────
SCREENSHOT_INTERVAL_SECONDS=2.0

# ── API Server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
